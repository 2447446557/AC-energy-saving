# ============ 边缘端环境配置 ============
# 复制本文件为 .env 后按实际修改

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs

# SQLite 数据库
SQLITE_PATH=data/edge.db

# 云端同步（仅客户端，不做云端服务）
CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_URL=http://127.0.0.1:9000/api
CLOUD_SYNC_TOKEN=
CLOUD_SYNC_INTERVAL=300

# MQTT（对接现场空调设备，也可用于开发期模拟）
# 启用后：
#   1. 边缘端订阅主题 ac/hospital/+/data 接收真实设备数据
#   2. 若 settings.yaml 中 mqtt.simulator_publisher=true，则同时启动虚拟发布器
#      （HospitalDataGenerator 生成仿真数据），形成端到端闭环测试
# 接入真实硬件后：将 MQTT_BROKER_HOST/MQTT_BROKER_PORT 改成现场网关，并将
#   settings.yaml 中 mqtt.simulator_publisher 改为 false
MQTT_ENABLED=false
MQTT_BROKER_HOST=127.0.0.1
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=edge-001

# 业务配置文件路径
SETTINGS_YAML=config/settings.yaml
