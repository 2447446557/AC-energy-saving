# ============ 边缘端环境配置 ============

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs

# SQLite 数据库
SQLITE_PATH=data/edge.db

# 云端同步（仅客户端，不做云端服务）
CLOUD_SYNC_ENABLED=false
CLOUD_SYNC_URL=http://127.0.0.1:9000/api
CLOUD_SYNC_TOKEN=
CLOUD_SYNC_INTERVAL=300

# ============ MQTT：启用，使用 Eclipse 公共测试 Broker ============
# 公共测试 Broker（免安装，开发/调试用）
# 接入真实硬件后：改为现场网关 IP/端口
MQTT_ENABLED=true
MQTT_BROKER_HOST=test.mosquitto.org
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=edge-001-test
# 生产环境可选配置（当前公共 Broker 不需要）
# MQTT_USERNAME=
# MQTT_PASSWORD=

# 业务配置文件路径
SETTINGS_YAML=config/settings.yaml
